{
  "$schema": "https://www.designtokens.org/tr/drafts/format/",
  "color": {
    "primitive": {
      "neutral-0": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [
            1,
            1,
            1
          ],
          "alpha": 1
        }
      },
      "neutral-950": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [
            0.06,
            0.07,
            0.09
          ],
          "alpha": 1
        }
      }
    },
    "semantic": {
      "surface": {
        "$type": "color",
        "$value": "{color.primitive.neutral-0}"
      },
      "text": {
        "$type": "color",
        "$value": "{color.primitive.neutral-950}"
      }
    }
  },
  "space": {
    "100": {
      "$type": "dimension",
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "200": {
      "$type": "dimension",
      "$value": {
        "value": 8,
        "unit": "px"
      }
    }
  }
}
